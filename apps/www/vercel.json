{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/quick-start",
      "permanent": true
    },
    {
      "source": "/r/pro/:path*",
      "destination": "/403",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/docs/:path*",
      "destination": "/llms.mdx/:path*"
    }
  ],
  "headers": []
}
