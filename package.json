{
  "name": "limeplay",
  "version": "1.0.0",
  "author": "Rohan Gupta <rohangupta1528@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winoffrg/limeplay.git"
  },
  "devDependencies": {
    "lefthook": "^2.1.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "turbo": "^2.9.14"
  },
  "license": "MIT",
  "packageManager": "bun@1.2.19",
  "private": true,
  "scripts": {
    "lint": "cd apps/www && ../../node_modules/.bin/eslint .",
    "lint:fix": "cd apps/www && ../../node_modules/.bin/eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "test:local": "bun run format && bun run lint:fix && cd apps/www && bun run build"
  },
  "workspaces": [
    "apps/*"
  ]
}
